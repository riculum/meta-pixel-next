{
  "name": "@riculum/meta-pixel-next",
  "version": "0.1.2",
  "description": "A tiny, type-safe Meta (Facebook) Pixel component for Next.js",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "next": ">=13.4.0",
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "meta pixel",
    "facebook pixel",
    "facebook conversions",
    "conversions api",
    "conversion tracking",
    "event tracking",
    "pixel integration",
    "marketing api",
    "ads tracking",
    "react facebook pixel",
    "nextjs",
    "next.js",
    "nextjs analytics",
    "typescript",
    "typescript facebook api"
  ]
}
